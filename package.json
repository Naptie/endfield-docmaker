{
  "name": "endfield-docmaker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "fl": "prettier --write . && eslint . --fix",
    "m": "tsx ./scripts/manage-messages.js",
    "mw": "tsx ./scripts/manage-messages.js --write && prettier --write ./messages"
  },
  "devDependencies": {
    "@eslint/compat": "latest",
    "@eslint/js": "latest",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@inlang/paraglide-js": "^2.15.2",
    "@internationalized/date": "^3.12.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "phosphor-svelte": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vite-plugin-compression2": "^2.5.3"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource-variable/sora": "^5.2.8",
    "@lucide/svelte": "^1.8.0",
    "@myriaddreamin/typst-ts-renderer": "0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "mode-watcher": "^1.1.0"
  },
  "packageManager": "pnpm@10.33.0"
}
